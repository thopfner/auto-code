{
  "name": "auto-forge-controller",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "schema:check": "tsx tools/check-schema.ts",
    "verify": "npm run lint && npm run typecheck && npm run schema:check && npm run test",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:worker": "tsx watch apps/worker/src/worker.ts",
    "dev:web": "vite --host 0.0.0.0 apps/web"
  },
  "dependencies": {
    "fastify": "^5.6.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
